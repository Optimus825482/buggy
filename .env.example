# Buggy Call - Environment Variables
# Hepsinin config.py'de default'u var. Sadece production'da degistirmen gerekenler:

# Production'da mutlaka degistir
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
SYSTEM_RESET_PASSWORD=518518Erkan

# Firebase (push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Database (Coolify MySQL servisi bunlari otomatik set eder)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=buggycall
# DB_USER=root
# DB_PASSWORD=

# Redis (opsiyonel, yoksa in-memory kullanir)
# REDIS_URL=redis://localhost:6379/0

# CORS (production'da domain'ini ekle)
# CORS_ORIGINS=https://siten.com
